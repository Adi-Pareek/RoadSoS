<resources>
    <style name="Theme.RoadSos" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/emergency_red</item>
        <item name="colorPrimaryDark">@color/emergency_red_dark</item>
        <item name="colorAccent">@color/emergency_red</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="editTextColor">@color/text_primary</item>
        <item name="colorControlNormal">@color/text_secondary</item>
        <item name="colorControlActivated">@color/emergency_red</item>
    </style>

    <style name="SOSButton">
        <item name="android:layout_width">200dp</item>
        <item name="android:layout_height">200dp</item>
        <item name="android:background">@drawable/sos_button_bg</item>
        <item name="android:text">@string/sos_button</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="android:textSize">42sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:elevation">8dp</item>
    </style>
    <style name="DarkDialog" parent="Theme.MaterialComponents.Dialog">
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="colorPrimary">@color/emergency_red</item>
    </style>
</resources>