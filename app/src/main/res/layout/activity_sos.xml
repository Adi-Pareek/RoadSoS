<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/sosRootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/bg_secondary"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/backButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="←"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:gravity="center"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Emergency SOS"
            android:textColor="@color/emergency_red"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/statusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● MONITORING"
            android:textColor="@color/status_safe"
            android:textSize="11sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- Main Content -->
    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Alert Icon -->
        <TextView
            android:id="@+id/alertIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠"
            android:textSize="64sp"
            android:visibility="gone"/>

        <!-- Countdown Circle -->
        <androidx.cardview.widget.CardView
            android:id="@+id/countdownCard"
            android:layout_width="200dp"
            android:layout_height="200dp"
            app:cardCornerRadius="100dp"
            app:cardBackgroundColor="@color/emergency_red"
            app:cardElevation="12dp"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/countdownNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30"
                    android:textColor="@color/text_white"
                    android:textSize="72sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="seconds"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Question Text -->
        <TextView
            android:id="@+id/questionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Possible accident detected."
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/subText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Are you safe? Emergency services will\nbe alerted if no response."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="40dp"/>

        <!-- Action Buttons -->
        <LinearLayout
            android:id="@+id/actionButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- I'm Safe Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/safButton"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="✓ I'M SAFE"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="@color/status_safe"
                app:cornerRadius="12dp"/>

            <!-- Need Help Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/helpButton"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="🆘 NEED HELP"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="@color/emergency_red"
                app:cornerRadius="12dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Emergency Activated Overlay -->
    <LinearLayout
        android:id="@+id/emergencyOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/emergency_red_dark"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🆘"
            android:textSize="80sp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMERGENCY ACTIVATED"
            android:textColor="@color/text_white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alerting your emergency contacts\nand sharing your live location"
            android:textColor="#CCFFFFFF"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginBottom="32dp"/>

        <!-- Sending Status -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#33FFFFFF"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/smsStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📱 Sending SMS to contacts..."
                    android:textColor="@color/text_white"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/locationStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 Sharing live location..."
                    android:textColor="@color/text_white"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/alertStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡ Emergency services notified..."
                    android:textColor="@color/text_white"
                    android:textSize="14sp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Cancel Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/cancelEmergency"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="CANCEL EMERGENCY"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#33FFFFFF"
            app:cornerRadius="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- Call Ambulance -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/callAmbulance"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📞 CALL 108 AMBULANCE"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="@color/text_white"
            android:textColor="@color/emergency_red"
            app:cornerRadius="12dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>